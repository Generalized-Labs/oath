{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oath.dev/schemas/registry-verdict-v1.json",
  "title": "Oath RegistryVerdict v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "expires_at", "package", "decision", "reason_code", "risk_score", "package_digest", "assessment_digest", "policy_digest", "rule_bundle_version", "limitations", "signature"],
  "properties": {
    "schema_version": { "const": 1 },
    "generated_at": { "type": "integer", "minimum": 0 },
    "expires_at": { "type": "integer", "minimum": 0 },
    "package": { "$ref": "#/$defs/identity" },
    "decision": { "enum": ["allow", "deny", "review", "unknown"] },
    "reason_code": { "enum": ["OATH_REGISTRY_ALLOWED", "OATH_REGISTRY_CRITICAL_BEHAVIOR", "OATH_REGISTRY_REVIEW_REQUIRED", "OATH_REGISTRY_SECRET_DETECTED", "OATH_REGISTRY_UNKNOWN"] },
    "risk_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "package_digest": { "$ref": "#/$defs/digest" },
    "assessment_digest": { "$ref": "#/$defs/digest" },
    "policy_digest": { "$ref": "#/$defs/digest" },
    "rule_bundle_version": { "type": "string", "minLength": 1 },
    "limitations": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "signature": { "$ref": "#/$defs/signature" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "nullableString": { "type": ["string", "null"] },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "registry", "integrity", "publisher", "publish_age_days", "repository"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "registry": { "type": "string", "minLength": 1 },
        "integrity": { "$ref": "#/$defs/nullableString" },
        "publisher": { "$ref": "#/$defs/nullableString" },
        "publish_age_days": { "type": ["integer", "null"], "minimum": 0 },
        "repository": { "$ref": "#/$defs/nullableString" }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "canonicalization", "public_key", "signature"],
      "properties": {
        "algorithm": { "const": "ed25519" },
        "canonicalization": { "const": "oath-json-v1" },
        "public_key": { "type": "string" },
        "signature": { "type": "string" }
      }
    }
  }
}
