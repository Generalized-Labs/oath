{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oath.dev/schemas/operational-drill-report-v2.schema.json",
  "title": "Oath OperationalDrillReport v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evidence_class", "release_commit", "drill_id", "drill_type", "started_at", "finished_at", "status", "environment", "assertions", "artifacts", "limitations"],
  "properties": {
    "schema_version": { "const": 2 },
    "evidence_class": { "const": "operational-drill" },
    "release_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "drill_id": { "type": "string", "minLength": 1 },
    "drill_type": { "enum": ["backup_restore", "dependency_outage", "key_compromise", "object_corruption", "process_kill", "regional_failover", "revocation_cache_outage", "split_view", "tenant_isolation", "webhook_replay"] },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["passed", "failed", "inconclusive"] },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "regions", "deployment_digest"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "regions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
        "deployment_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "assertions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/assertion" } },
    "rpo_minutes": { "type": "number", "minimum": 0 },
    "rto_minutes": { "type": "number", "minimum": 0 },
    "artifacts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifact" } },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "assertion": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "passed", "observed"],
      "properties": { "name": { "type": "string" }, "passed": { "type": "boolean" }, "observed": { "type": "string" } }
    },
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["uri", "sha256"],
      "properties": { "uri": { "type": "string", "minLength": 1 }, "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" } }
    }
  }
}
