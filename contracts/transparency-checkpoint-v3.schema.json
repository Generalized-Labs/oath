{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oath.dev/schemas/transparency-checkpoint-v3.schema.json",
  "title": "Oath TransparencyCheckpoint v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evidence_class", "release_commit", "log_id", "tree_size", "root_hash", "issued_at", "expires_at", "revocation_epoch", "signatures", "witnesses"],
  "properties": {
    "schema_version": { "const": 3 },
    "evidence_class": { "const": "transparency-checkpoint" },
    "release_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "log_id": { "type": "string", "minLength": 1 },
    "tree_size": { "type": "integer", "minimum": 0 },
    "root_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "revocation_epoch": { "type": "integer", "minimum": 0 },
    "rekor_bundle_digest": { "type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$" },
    "signatures": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/signature" } },
    "witnesses": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/signature" } }
  },
  "$defs": {
    "signature": {
      "type": "object", "additionalProperties": false,
      "required": ["identity", "algorithm", "key_id", "signature"],
      "properties": {
        "identity": { "type": "string", "minLength": 1 },
        "algorithm": { "const": "ed25519" },
        "key_id": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 }
      }
    }
  }
}
